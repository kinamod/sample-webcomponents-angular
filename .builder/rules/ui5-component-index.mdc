## Icons (@ui5/webcomponents-icons)

Import individual icons as needed:

import '@ui5/webcomponents-icons/dist/palette.js';
import '@ui5/webcomponents-icons/dist/settings.js';
import '@ui5/webcomponents-icons/dist/home.js';
```

Browse all icons: https://ui5.github.io/webcomponents/icons/

## Angular Integration Patterns

### Accessing Component References
```typescript
import { Component, ViewChild, ElementRef } from '@angular/core';

@Component({...})
export class MyComponent {
  @ViewChild('dialog') dialog: ElementRef;

  openDialog() {
    this.dialog.nativeElement.show();
  }

  closeDialog() {
    this.dialog.nativeElement.close();
  }
}
```

### Event Handling
```html
<!-- Use (event) binding -->
<ui5-button (click)="handleClick($event)">Click</ui5-button>
<ui5-input (input)="handleInput($event)"></ui5-input>
<ui5-list (selectionChange)="handleSelection($event)"></ui5-list>
```

```typescript
handleClick(event: any) {
  // UI5 events use event.detail
  console.log(event.detail);
}
```

### Reading/Writing Values
```typescript
@ViewChild('input') input: ElementRef;

getValue() {
  return this.input.nativeElement.value;
}

setValue(val: string) {
  this.input.nativeElement.value = val;
}
```

